{
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "medium"
  },
  "permissions": {
    "deny": [
      "Read(./exercises/**/.meta/solution.py)",
      "Read(./exercises/**/.meta/stub.py)",
      "Edit(./exercises/**/test_problem.py)",
      "Write(./exercises/**/test_problem.py)",
      "Edit(./exercises/marathon.py)",
      "Edit(./exercises/conftest.py)",
      "Edit(./exercises/pytest.ini)",
      "Grep(./exercises/**/.meta/solution.py)",
      "Grep(./exercises/**/.meta/stub.py)",
      "Bash(cat *.meta/solution.py)",
      "Bash(cat *.meta/stub.py)",
      "Read(./exercises/answers/**)",
      "Grep(./exercises/answers/**)"
    ],
    "allow": [
      "Read(./exercises/**/README.md)",
      "Read(./exercises/**/problem.py)",
      "Read(./exercises/**/test_problem.py)",
      "Read(./exercises/**/.meta/hints.md)",
      "Read(./exercises/**/.meta/notes.md)",
      "Edit(./exercises/**/problem.py)",
      "Write(./exercises/**/problem.py)",
      "Edit(./exercises/**/.meta/hints.md)",
      "Write(./exercises/**/.meta/hints.md)",
      "Edit(./exercises/**/.meta/notes.md)",
      "Write(./exercises/**/.meta/notes.md)",
      "Bash(python marathon.py status)",
      "Bash(python marathon.py next)",
      "Bash(python marathon.py run:*)",
      "Bash(python marathon.py list:*)",
      "Bash(python marathon.py hint:*)",
      "Bash(python marathon.py reset:*)",
      "Bash(python marathon.py submit:*)",
      "Bash(python marathon.py peer:*)",
      "Bash(python marathon.py watch:*)",
      "Bash(python marathon.py verify)",
      "Bash(python marathon.py review)",
      "Bash(python marathon.py challenge:*)",
      "Bash(python marathon.py challenge-peer:*)",
      "Bash(python marathon.py kata:*)",
      "Bash(python marathon.py tag:*)",
      "Bash(python marathon.py recommend)",
      "Bash(python marathon.py badges)",
      "Bash(python marathon.py export)",
      "Bash(python marathon.py import-progress:*)",
      "Bash(python marathon.py export-obsidian:*)",
      "Bash(python marathon.py new:*)",
      "Bash(python marathon.py import:*)",
      "Bash(python marathon.py lint-exercises)",
      "Bash(python marathon.py completion:*)"
    ],
    "ask": [
      "Bash(python marathon.py reveal:*)"
    ]
  }
}
